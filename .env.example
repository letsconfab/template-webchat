# Environment: development | production
# In production the app refuses to start with default/weak secrets.
ENVIRONMENT=development

# Application Configuration
PURPOSE="You are a helpful AI assistant that answers questions based on the provided knowledge base."
GAURDRAILS="Be polite and professional. Do not provide harmful, illegal, or unethical advice. Always base answers on the provided knowledge base documents."

# Feature Flags
STORE_CHAT_THREADS=true
USE_EMAIL_AS_IDENTIFIER=true

# Knowledge Base Configuration
KB_ASSETS_DIR="./kb_assets"

# Langfuse Observability (optional - leave empty to disable)
LANGFUSE_BASE_URL=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""

# OpenAI API Key (required for embeddings and LLM)
OPENAI_API_KEY="sk-..."

# Database Configuration
# PostgreSQL with asyncpg driver for FastAPI async support
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webchat_db

# JWT Configuration
# IMPORTANT: Change this to a strong, random secret key (>= 32 chars)!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Frontend origin(s) for CORS and the OAuth popup postMessage.
# Comma-separated list allowed; the first entry is the primary origin.
FRONTEND_URL=http://localhost:5173

# Neo4j (also read by docker-compose for NEO4J_AUTH and its healthcheck)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE-ME

# Qdrant vector store
QDRANT_URL=http://localhost:6333

# Knowledge base cache directory (Drive sync downloads land here)
KB_CACHE_DIR=./kb_cache

# Google Drive OAuth (optional — leave empty to disable Drive sync)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/drive/callback

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=enter-your-username
SMTP_PASSWORD=enter-your-password 
FROM_EMAIL=enter-your-email
